@model Journal.Models.ImageAsset

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Bearbeitung";
}
<div class = "mt-4">
<h1>Bildinfo bearbeitung</h1>
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="FileName" />
            <input type="hidden" asp-for="Url" />
            <input type="hidden" asp-for="UploadedAt" />
            <div class="mb-3">
                <img src="@Model.Url" style="max-width: 200px; border-radius: 8px;" class="mt-2 mb-2" />
            </div>
            <div class="form-group mb-3">
                <label asp-for="ImageName" class="control-label">Titel</label>
                <input asp-for="ImageName" class="form-control" />
                <span asp-validation-for="ImageName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Type" class="control-label">Typ</label>
                <select asp-for="Type" asp-items="Html.GetEnumSelectList<ImageType>()" class="form-control"></select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Speichern</button>
                <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
            </div>
        </form>
    </div>
</div>
</div>