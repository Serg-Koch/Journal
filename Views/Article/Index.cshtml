@model Journal.Models.PaginatedList<Journal.Models.Note>

@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Artikeln";
}
<div class="container mt-4">
    <h1>Artikeln</h1>
    <div class="row">
    @foreach (var item in Model)
    {
        if(item.IsPublished)
        {
            <div class="col-lg-4 mb-4">
            <div style="width: 400px; height: 500px; display: flex; flex-direction: column;">
                @*Image*@
                @if(@item.ThumbnailUrl == "" || System.IO.File.Exists(item.ThumbnailUrl))
                  {
                    <div class = "img-position">
                        <img class="img-thumbnail-render" loading="lazy" src="/uploads/f5abffe2-4933-42d0-b10f-ca33d915c9ef.png" alt="" >
                    </div>
                }
                else
                {
                    <div class = "img-position">
                        <img class="img-thumbnail-render" loading="lazy" src="@item.ThumbnailUrl" alt="" >
                    </div>
                }
                @*Buttons*@
                <div class="buttons-render">
                    <h4 class="card-title">@Html.DisplayFor(modelItem => item.Title)</h4>
                    <p class="card-text-truncate">@Html.DisplayFor(modelItem => item.Introduce)</p>
                    <a class="btn btn-primary" asp-controller="Article" asp-action="Details" asp-route-id="@item.Id" target="_blank">Lesen</a>
                </div>
            </div>
        </div>
        }
    }
    @{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    }
    <div class="container d-flex justify-content-between">
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex - 1)"
           class="btn btn-dark @prevDisabled">
            Vorletzte Seite
        </a>
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex + 1)"
           class="btn btn-dark @nextDisabled">
           Nächste Seite 
        </a>
    </div>
</div>