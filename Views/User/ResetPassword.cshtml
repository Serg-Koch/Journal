@using Microsoft.AspNetCore.Identity
@model AccountManager
@{
    Layout = "_AdminLayout";
}
<h2>Ein Passwort für<b>@Model.UserName</b> ändern</h2>
<div class = "container">
<form asp-action="ResetPassword" method="post">
    @*<input type="hidden" asp-for="Id" />*@
    <input type="hidden" asp-for="UserName" />
    <div class="form-group mb-3">
        <label asp-for="Password" class="form-label">Neues Passwort</label>
        <input asp-for="Password" class="form-control" type="password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="ConfirmPassword" class="form-label">Passwort wieder eingeben</label>
        <input asp-for="ConfirmPassword" class="form-control" type="password" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Passwort zurücksetzen</button>
    <a asp-action="Index" class="btn btn-secondary">Abbrechen</a>
</form>