<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | Alex Polygon</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header>
        <nav class="navbar navbar-expand-sm bg-dark navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Alex-Polygon</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#collapsibleNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="collapsibleNavbar">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Article" asp-action="Index">Artikel</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Render" asp-action="Index">Galerie</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Video">Animationen</a>
                    </li>
                </ul>
            </div>
            <div class="justify-content flex-end">
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <a class="nav-item btn btn-primary" href="/admin-panel/article">CMS</a>
                    <a class="nav-item btn btn-danger" href="/logout">Logout</a>
                }
                else
                {
                    <a class="nav-item btn btn-primary" href="/login">Anmelden</a>
                }
            </div>
        </div>
        </nav>
</header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted bg-dark text-center">
        <div class="container">
            <span>&copy;Alex Poligon - 2026</span>
            <a class="text-muted  text-decoration-none" asp-controller="Home" asp-action="Impressum">Impressum</a>
            <a class="text-muted  text-decoration-none" asp-controller="Home" asp-action="Privacy">Datenschutz</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
